APP_NAME=Boyeep Template API
APP_ENV=development
APP_PORT=8080
APP_HOST=0.0.0.0
APP_BASE_URL=http://localhost:8080
FRONTEND_APP_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://flippy-playground.vercel.app

DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=app_db
DB_USER=postgres
DB_PASSWORD=db_password
